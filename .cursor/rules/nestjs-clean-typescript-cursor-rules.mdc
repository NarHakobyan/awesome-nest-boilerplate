## 🚨 CRITICAL: Entity Module Ownership Rules
- **One entity per module**: Every entity must be owned by exactly one feature module
- **No cross-module entity sharing**: Do not import or use entities from other modules
- **Use services for cross-module communication**: If you need data from another module, use their service methods
- **Create dedicated entities**: If similar data structures are needed, create separate entities per module
- **Exception for shared entities**: Only `AbstractEntity` and entities in `src/common/` can be shared

## Module Implementation
```ts
// feature.module.ts
@Module({
  imports: [
    TypeOrmModule.forFeature([FeatureEntity])
  ],
  controllers: [FeatureNatsController],
  providers: [
    FeatureQueryService,
    FeatureCommandService,
    FeatureSagas,
    ...handlers
  ]
})
export class FeatureModule {}

// feature.command-service.ts (based on actual implementation)
@Injectable()
export class PostService {
  constructor(
    @InjectRepository(PostEntity)
    private postRepository: Repository<PostEntity>,
    private commandBus: CommandBus,
  ) {}

  @Transactional()
  createPost(userId: Uuid, createPostDto: CreatePostDto): Promise<PostEntity> {
    return this.commandBus.execute<CreatePostCommand, PostEntity>(
      new CreatePostCommand(userId, createPostDto),
    );
  }
}

// feature.query-service.ts
@Injectable()
export class FeatureQueryService {
  constructor(
    @InjectRepository(FeatureEntity)
    private readonly repo: Repository<FeatureEntity>,
  ) {}

  async find(id: string): Promise<Feature> {
    return this.repo.findOneOrFail({ where: { id } });
  }
}
```

## CQRS Pattern
1. **Commands (Based on Actual Implementation)**
   ```ts
   // create-post.command.ts
   export class CreatePostCommand implements ICommand {
     constructor(
       public readonly userId: Uuid,
       public readonly createPostDto: CreatePostDto,
     ) {}
   }

   // create-post.handler.ts
   @CommandHandler(CreatePostCommand)
   export class CreatePostHandler implements ICommandHandler<CreatePostCommand, PostEntity> {
     constructor(
       @InjectRepository(PostEntity)
       private postRepository: Repository<PostEntity>,
       @InjectRepository(PostTranslationEntity)
       private postTranslationRepository: Repository<PostTranslationEntity>,
     ) {}

     async execute(command: CreatePostCommand): Promise<PostEntity> { // ✅ Explicit return type required
       const { userId, createPostDto } = command;
       const postEntity = this.postRepository.create({ userId });
       // ... implementation
       return postEntity;
     }
   }
   ```

2. **Events**
   ```ts
   // feature-created.event.ts
   export class FeatureCreatedEvent {
     constructor(public readonly feature: Feature) {}
   }

   // feature-created.handler.ts
   @EventsHandler(FeatureCreatedEvent)
   export class FeatureCreatedHandler {
     async handle(event: FeatureCreatedEvent) {
       // Implementation
     }
   }
   ```

3. **Queries**
   ```ts
   // get-feature.query.ts
   export class GetFeatureQuery {
     constructor(public readonly id: string) {}
   }

   // get-feature.handler.ts
   @QueryHandler(GetFeatureQuery)
   export class GetFeatureHandler {
     async execute(query: GetFeatureQuery) {
       // Implementation
     }
   }
   ```

## Common Module Usage
```ts
// Using base entity class
import { AbstractEntity } from '../../common/abstract.entity.ts';

// Using base DTO class
import { AbstractDto } from '../../common/dto/abstract.dto.ts';

// Using shared config service
import { ApiConfigService } from '../../shared/services/api-config.service.ts';
```

## Error Handling
```ts
// feature.exceptions.ts
export class FeatureNotFoundException extends NotFoundException {
  constructor(id: string) {
    super(`Feature with id ${id} not found`);
  }
}

// Usage in service
async find(id: string): Promise<Feature> {
  const feature = await this.repo.findOne({ where: { id } });
  if (!feature) {
    throw new FeatureNotFoundException(id);
  }
  return feature;
}
```

## Testing
```ts
describe('FeatureCommandService', () => {
  let service: FeatureCommandService;
  let commandBus: CommandBus;

  beforeEach(async () => {
    const module = await Test.createTestingModule({
      providers: [
        FeatureCommandService,
        {
          provide: CommandBus,
          useValue: { execute: jest.fn() },
        },
      ],
    }).compile();

    service = module.get(FeatureCommandService);
    commandBus = module.get(CommandBus);
  });

  it('should execute command', async () => {
    const command = new CreateFeatureCommand({});
    await service.execute(command);
    expect(commandBus.execute).toHaveBeenCalledWith(command);
  });
});
```
