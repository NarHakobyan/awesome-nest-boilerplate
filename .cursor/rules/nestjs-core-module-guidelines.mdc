# NestJS Core Module Guidelines

## Global filters for exception handling.

## Core Functionality Structure
```
service/
├── src/
│   ├── database/
│   │   └── migrations/    # TypeORM migrations
│   ├── filters/          # Global exception filters
│   ├── interceptors/     # Global interceptors
│   │   ├── rpc-logging.interceptor.ts
│   │   └── language.interceptor.ts
│   ├── entity-subscribers/ # Entity lifecycle hooks
│   └── shared/           # Service-wide shared code
```

## Cross-Cutting Concerns

1. **RPC Logging**
```ts
@Injectable()
export class RpcLoggingInterceptor implements NestInterceptor {
  logger = new Logger(RpcLoggingInterceptor.name);

  intercept(context: ExecutionContext, next: CallHandler) {
    const now = Date.now();
    const pattern = context
      .switchToRpc()
      .getContext<NatsContext>()
      .getSubject();

    const data = context.switchToRpc().getData();
    this.logger.debug(
      `Received subject: ${pattern}, data: ${JSON.stringify(data)}`,
    );

    return next.handle().pipe(
      tap((returnData) =>
        this.logger.debug(
          `End subject: ${pattern}, ${Date.now() - now}ms, data: ${JSON.stringify(returnData)}`,
        ),
      ),
    );
  }
}
```

2. **Language Handling**
```ts
@Injectable()
export class LanguageInterceptor implements NestInterceptor {
  constructor(private readonly cls: ClsService) {}

  intercept(context: ExecutionContext, next: CallHandler) {
    const type = context.getType<ContextType | 'grammy'>();
    let language: string | undefined;

    // Extract language from different context types
    switch (type) {
      case 'http':
        language = context.switchToHttp().getRequest().headers['x-language-code'];
        break;
      case 'rpc':
        language = context.switchToRpc().getData().__language;
        break;
    }

    // Set language in context
    this.cls.set(ContextTypeEnum.LANGUAGE,
      language && LanguageCodeEnum[language]
        ? language
        : LanguageCodeEnum.EN
    );

    return next.handle();
  }
}
```

## Service Configuration

1. **App Module Setup**
```ts
@Module({
  imports: [
    // Database
    TypeOrmModule.forRootAsync({
      useFactory: (config: ConfigService) => ({
        type: 'postgres',
        host: config.get('DB_HOST'),
        port: config.get('DB_PORT'),
        username: config.get('DB_USERNAME'),
        password: config.get('DB_PASSWORD'),
        database: config.get('DB_DATABASE'),
        entities: [__dirname + '/**/*.entity{.ts,.js}'],
        migrations: [__dirname + '/database/migrations/*{.ts,.js}'],
        namingStrategy: new SnakeNamingStrategy(),
        logging: config.get('NODE_ENV') === 'development',
      }),
      inject: [ConfigService],
    }),

    // Cross-cutting concerns
    ClsModule.forRoot({
      global: true,
      middleware: { mount: true },
    }),
  ],
  providers: [
    // Global interceptors
    {
      provide: APP_INTERCEPTOR,
      useClass: RpcLoggingInterceptor,
    },
    {
      provide: APP_INTERCEPTOR,
      useClass: LanguageInterceptor,
    },
  ],
})
export class AppModule {}
```

