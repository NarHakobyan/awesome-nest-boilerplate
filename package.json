{
  "name": "awesome-nestjs-boilerplate",
  "version": "11.0.0",
  "description": "Awesome NestJS Boilerplate, Typescript, Postgres, TypeORM",
  "author": "Narek Hakobyan <narek.hakobyan.07@gmail.com>",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build:prod": "nest build",
    "start:dev": "vite",
    "nest:start": "nest start ./src/main.ts",
    "nest:start:dev": "nest start --watch",
    "nest:start:debug": "nest start --debug --watch",
    "nest:watch": "nest start --watch ./src/main.ts",
    "start:prod": "node dist/main.js",
    "start:dev:bun": "bun run ./src/main.ts",
    "watch:bun": "bun run --watch ./src/main.ts",
    "build:bun": "bun build --external=class-validator --external=@nestjs/sequelize --external=@mikro-orm/core --external=@nestjs/mongoose --external=mock-aws-s3 --external=hbs --external=aws-sdk --external=nock --external=@nestjs/websockets/socket-module --external=class-transformer --external=@nestjs/microservices --define process.env.NODE_ENV:\"'production'\" --target=bun --minify ./dist/main.js --outdir=dist --format esm ./src/main.ts",
    "typeorm": "typeorm-ts-node-esm",
    "migration:generate": "pnpm run typeorm migration:generate -d ormconfig.ts",
    "migration:create": "pnpm run typeorm migration:create",
    "generate": "nest g -c awesome-nestjs-schematics --no-spec",
    "g": "pnpm run generate",
    "migration:run": "pnpm run typeorm migration:run -d ormconfig.ts",
    "migration:revert": "pnpm run typeorm migration:revert -d ormconfig.ts",
    "migration:show": "pnpm run typeorm migration:show -d ormconfig.ts",
    "schema:drop": "pnpm run typeorm schema:drop -d ormconfig.ts",
    "dev": "concurrently \"pnpm run nest:start\" \"pnpm run tunnel\"",
    "dev:watch": "pnpm run nest:watch",
    "tunnel": "cloudflared tunnel run --token $CLOUDFLARE_TUNNEL_TOKEN Pixera_Local_API",
    "lint": "eslint .",
    "lint:changes": "biome check --staged",
    "lint:fix": "eslint --fix .",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:cov": "NODE_ENV=test jest --coverage",
    "test:debug": "NODE_ENV=test node --inspect-brk -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_ENV=test jest --config ./test/jest-e2e.json",
    "docs:dev": "vuepress dev -p 7070",
    "docs:build": "DEPLOY_ENV=gh-pages vuepress build",
    "docs:deploy": "pnpm run docs:build && gh-pages -d .vuepress/dist",
    "prepare": "husky",
    "release": "release-it"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.4",
    "@aws-sdk/client-s3": "^3.864.0",
    "@aws-sdk/client-secrets-manager": "^3.916.0",
    "@fal-ai/client": "^1.7.2",
    "@golevelup/nestjs-stripe": "^0.9.3",
    "@google/genai": "^1.29.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.1.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@noble/ed25519": "^3.0.0",
    "@revenuecat/purchases-js": "^1.18.0",
    "ai": "^6.0.31",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "blurhash": "^2.0.5",
    "bullmq": "^5.28.0",
    "class-transformer": "~0.5.1",
    "class-validator": "~0.14.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "firebase-admin": "^13.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "limax": "^4.1.0",
    "lodash": "^4.17.21",
    "meilisearch": "^0.54.0",
    "mime-types": "^3.0.1",
    "morgan": "^1.10.1",
    "nanoid": "^5.1.6",
    "nestjs-cls": "^6.0.1",
    "nestjs-i18n": "^10.5.1",
    "parse-duration": "^2.1.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.4",
    "stripe": "^19.2.0",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.8.1",
    "typeorm": "0.3.20",
    "typeorm-transactional": "~0.5.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.33.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.6",
    "@stylistic/eslint-plugin": "^5.2.3",
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.0",
    "@swc/plugin-transform-imports": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.20",
    "@types/mime-types": "^3.0.1",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.17.1",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "awesome-nestjs-schematics": "^10.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "esbuild": "^0.25.9",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-canonical": "^5.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-helpers": "^2.0.1",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^3.0.4",
    "eslint-plugin-unicorn": "^60.0.0",
    "gh-pages": "^6.3.0",
    "globals": "^16.3.0",
    "http-proxy": "^1.18.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "knip": "^6.0.3",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "taze": "^19.1.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1",
    "vite": "7.1.2",
    "vite-plugin-node": "^7.0.0",
    "vue": "^3.5.16",
    "vuepress": "2.0.0-rc.19"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "npx @biomejs/biome lint --write",
      "eslint --fix",
      "git add"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
